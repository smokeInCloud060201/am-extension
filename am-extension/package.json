{
  "name": "am-extension",
  "displayName": "Agent Management",
  "description": "AM Task Orchestrator VS Code Extension",
  "publisher": "karson",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onUri"
  ],
  "main": "./out/extension.js",
  "bin": {
    "am": "./bin/am.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "am.startTask",
        "title": "AM: Start Task"
      }
    ],
    "keybindings": [
      {
        "command": "am.startTask",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus || !editorTextFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "dotenv": "^16.4.5"
  }
}
